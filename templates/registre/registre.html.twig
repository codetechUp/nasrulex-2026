{% extends 'base.html.twig' %}

{% block body %}
<!-- Hero Section Inscription -->
<section class="min-h-screen relative flex items-center justify-center overflow-hidden bg-gradient-to-br from-dark-900 via-primary-900 to-dark-800 py-20">
    <!-- Background Animations -->
    <div class="absolute inset-0">
        <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-primary-500 rounded-full opacity-20 blur-3xl animate-float"></div>
        <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-accent-500 rounded-full opacity-30 blur-3xl animate-float" style="animation-delay: 2s;"></div>
    </div>
    
    <div class="container mx-auto px-4 relative z-10">
        <div class="max-w-4xl mx-auto">
            <!-- En-tête -->
            <div class="text-center mb-12" data-aos="fade-down">
                <div class="inline-flex items-center px-6 py-3 rounded-full bg-white/10 backdrop-blur-sm border border-white/20 mb-6">
                    <span class="w-2 h-2 bg-primary-400 rounded-full mr-3 animate-pulse"></span>
                    <span class="text-white font-semibold text-sm">REJOIGNEZ LA COMMUNAUTÉ NASRULEX</span>
                </div>
                <h1 class="text-4xl md:text-5xl font-black text-white mb-6">
                    Créez votre <span class="text-gradient">compte</span>
                </h1>
                <p class="text-xl text-gray-300">
                    Accédez à l'ensemble de nos ressources juridiques et fiscales
                </p>
            </div>

            <!-- Flash Messages -->
            {% for message in app.flashes('success') %}
            <div class="max-w-2xl mx-auto mb-8" data-aos="fade-up">
                <div class="bg-green-500/20 border border-green-400/30 text-green-100 px-6 py-4 rounded-2xl backdrop-blur-sm text-center">
                    <i class="fas fa-check-circle mr-2"></i>
                    {{ message }}
                </div>
            </div>
            {% endfor %}

            <!-- Formulaire Principal -->
            <div class="glass-effect rounded-3xl p-8 md:p-12 shadow-2xl" data-aos="fade-up" data-aos-delay="200">
                <form class="needs-validation" action="" method="post" novalidate>
                    <!-- Section Utilisateur Principal -->
                    <div class="mb-12" data-aos="fade-up" data-aos-delay="300">
                        <div class="flex items-center mb-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-primary-600 rounded-2xl flex items-center justify-center mr-4">
                                <i class="fas fa-user text-white text-lg"></i>
                            </div>
                            <div>
                                <h3 class="text-2xl font-bold text-white">Utilisateur principal</h3>
                                <p class="text-gray-300">Informations personnelles</p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Civilité -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Civilité</label>
                                <div class="relative">
                                    <select class="w-full px-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white appearance-none focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" name="civilite" required>
                                        <option value="" class="text-gray-800">Sélectionnez</option>
                                        <option value="Mr" class="text-gray-800">Monsieur</option>
                                        <option value="MD" class="text-gray-800">Madame</option>
                                    </select>
                                    <i class="fas fa-chevron-down absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-400 pointer-events-none"></i>
                                </div>
                                <div class="text-red-400 text-sm mt-2 hidden" data-error="civilite">
                                    La civilité est requise
                                </div>
                            </div>

                            <!-- Nom -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Nom</label>
                                <input type="text" name="username" class="w-full px-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Votre nom" required>
                                <div class="text-red-400 text-sm mt-2 hidden" data-error="username">
                                    Le nom est requis
                                </div>
                            </div>

                            <!-- Prénom -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Prénom</label>
                                <input type="text" name="prenom" class="w-full px-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Votre prénom" required>
                                <div class="text-red-400 text-sm mt-2 hidden" data-error="prenom">
                                    Le prénom est requis
                                </div>
                            </div>

                            <!-- Téléphone -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Téléphone</label>
                                <input type="text" name="telephone" class="w-full px-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Votre numéro" required>
                                <div class="text-red-400 text-sm mt-2 hidden" data-error="telephone">
                                    Le téléphone est requis
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Section Raison Sociale -->
                    <div class="mb-12" data-aos="fade-up" data-aos-delay="400">
                        <div class="flex items-center mb-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-accent-500 to-accent-600 rounded-2xl flex items-center justify-center mr-4">
                                <i class="fas fa-building text-white text-lg"></i>
                            </div>
                            <div>
                                <h3 class="text-2xl font-bold text-white">Raison sociale</h3>
                                <p class="text-gray-300">Informations professionnelles (optionnel)</p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Nom Structure -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Nom de votre structure</label>
                                <input type="text" name="nom_S" class="w-full px-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Nom de l'entreprise">
                            </div>

                            <!-- Adresse Structure -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Adresse</label>
                                <input type="text" name="Adresse_S" class="w-full px-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Adresse de la structure">
                            </div>

                            <!-- Téléphone Structure -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Téléphone</label>
                                <input type="text" name="telephone_S" class="w-full px-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Téléphone professionnel">
                            </div>

                            <!-- Ninea -->
                            <div>
                                <label class="block text-white font-semibold mb-3">NINEA</label>
                                <input type="text" name="numero_I_F" class="w-full px-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Numéro NINEA">
                            </div>
                        </div>
                    </div>

                    <!-- Section Données de Connexion -->
                    <div class="mb-12" data-aos="fade-up" data-aos-delay="500">
                        <div class="flex items-center mb-8">
                            <div class="w-12 h-12 bg-gradient-to-br from-primary-500 to-accent-500 rounded-2xl flex items-center justify-center mr-4">
                                <i class="fas fa-lock text-white text-lg"></i>
                            </div>
                            <div>
                                <h3 class="text-2xl font-bold text-white">Données de connexion</h3>
                                <p class="text-gray-300">Créez vos identifiants</p>
                            </div>
                        </div>

                        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                            <!-- Email -->
                            <div class="md:col-span-2">
                                <label class="block text-white font-semibold mb-3">Email</label>
                                <div class="relative">
                                    <i class="fas fa-envelope absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                                    <input type="email" name="email" class="w-full pl-12 pr-4 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="votre@email.com" required>
                                </div>
                                <div class="text-red-400 text-sm mt-2 hidden" data-error="email">
                                    Un email valide est requis
                                </div>
                            </div>

                            <!-- Mot de passe -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Mot de passe</label>
                                <div class="relative">
                                    <i class="fas fa-key absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                                    <input type="password" name="password" id="password" class="w-full pl-12 pr-12 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Votre mot de passe" required>
                                    <button type="button" class="absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-white transition-colors" onclick="togglePassword('password')">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <div class="text-red-400 text-sm mt-2 hidden" data-error="password">
                                    Le mot de passe est requis
                                </div>
                            </div>

                            <!-- Confirmation Mot de passe -->
                            <div>
                                <label class="block text-white font-semibold mb-3">Confirmez le mot de passe</label>
                                <div class="relative">
                                    <i class="fas fa-key absolute left-4 top-1/2 transform -translate-y-1/2 text-gray-400"></i>
                                    <input type="password" name="confirm_password" id="confirm_password" class="w-full pl-12 pr-12 py-4 bg-white/10 border border-white/20 rounded-2xl text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-primary-500 focus:border-transparent" placeholder="Confirmez le mot de passe" required>
                                    <button type="button" class="absolute right-4 top-1/2 transform -translate-y-1/2 text-gray-400 hover:text-white transition-colors" onclick="togglePassword('confirm_password')">
                                        <i class="fas fa-eye"></i>
                                    </button>
                                </div>
                                <div class="text-red-400 text-sm mt-2 hidden" data-error="confirm_password">
                                    La confirmation est requise
                                </div>
                            </div>

                            <!-- Indicateur Force Mot de passe -->
                            <div class="md:col-span-2">
                                <div class="bg-white/5 rounded-xl p-4">
                                    <div class="flex items-center justify-between mb-2">
                                        <span class="text-gray-300 text-sm">Force du mot de passe</span>
                                        <span class="text-gray-300 text-sm" id="password-strength-text">Faible</span>
                                    </div>
                                    <div class="w-full bg-white/10 rounded-full h-2">
                                        <div id="password-strength-bar" class="h-2 rounded-full bg-red-500 transition-all duration-500" style="width: 0%"></div>
                                    </div>
                                    <div class="text-gray-400 text-xs mt-2">
                                        Utilisez au moins 8 caractères avec des majuscules, minuscules et chiffres
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Conditions -->
                    <div class="mb-8" data-aos="fade-up" data-aos-delay="600">
                        <div class="flex items-start">
                            <div class="flex items-center h-5">
                                <input type="checkbox" id="conditions" class="w-4 h-4 text-primary-600 bg-white/10 border-white/20 rounded focus:ring-primary-500 focus:ring-2" required>
                            </div>
                            <label for="conditions" class="ml-3 text-gray-300">
                                J'accepte les 
                                <a href="{{path('condition')}}" class="text-primary-400 hover:text-primary-300 font-semibold transition-colors">termes et conditions</a>
                                d'utilisation de Nasrulex
                            </label>
                        </div>
                        <div class="text-red-400 text-sm mt-2 hidden" data-error="conditions">
                            Vous devez accepter les termes et conditions
                        </div>
                    </div>

                    <!-- Bouton Soumission -->
                    <div class="text-center" data-aos="fade-up" data-aos-delay="700">
                        <button type="submit" class="group bg-gradient-to-r from-primary-500 to-accent-500 text-white px-12 py-4 rounded-2xl font-bold hover:from-primary-600 hover:to-accent-600 transition-all duration-300 transform hover:scale-105 shadow-2xl hover:shadow-3xl min-w-[200px]">
                            <span class="flex items-center justify-center">
                                <i class="fas fa-rocket mr-2 group-hover:scale-110 transition-transform"></i>
                                Créer mon compte
                            </span>
                        </button>
                    </div>
                </form>

                <!-- Lien Connexion -->
                <div class="text-center mt-8 pt-8 border-t border-white/20" data-aos="fade-up" data-aos-delay="800">
                    <p class="text-gray-300">
                        Vous avez déjà un compte ?
                        <a href="{{path('login')}}" class="text-primary-400 hover:text-primary-300 font-semibold transition-colors group">
                            Connectez-vous
                            <i class="fas fa-arrow-right ml-1 group-hover:translate-x-1 transition-transform"></i>
                        </a>
                    </p>
                </div>
            </div>
        </div>
    </div>
</section>

<script>
// Validation personnalisée avec animations
document.addEventListener('DOMContentLoaded', function() {
    const form = document.querySelector('.needs-validation');
    const password = document.getElementById('password');
    const confirmPassword = document.getElementById('confirm_password');
    const strengthBar = document.getElementById('password-strength-bar');
    const strengthText = document.getElementById('password-strength-text');

    // Fonction pour afficher les erreurs avec animation
    function showError(field, message) {
        const errorElement = document.querySelector(`[data-error="${field}"]`);
        if (errorElement) {
            errorElement.textContent = message;
            errorElement.classList.remove('hidden');
            errorElement.style.opacity = '0';
            errorElement.style.transform = 'translateY(-10px)';
            
            setTimeout(() => {
                errorElement.style.opacity = '1';
                errorElement.style.transform = 'translateY(0)';
            }, 10);
        }
    }

    function hideError(field) {
        const errorElement = document.querySelector(`[data-error="${field}"]`);
        if (errorElement) {
            errorElement.classList.add('hidden');
        }
    }

    // Validation en temps réel
    form.addEventListener('input', function(e) {
        const field = e.target.name;
        const value = e.target.value;
        
        hideError(field);
        
        if (field === 'email' && value) {
            const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
            if (!emailRegex.test(value)) {
                showError(field, 'Format d\'email invalide');
            }
        }
        
        if (field === 'password') {
            updatePasswordStrength(value);
        }
        
        if (field === 'confirm_password' && value !== password.value) {
            showError(field, 'Les mots de passe ne correspondent pas');
        }
    });

    // Force du mot de passe
    function updatePasswordStrength(password) {
        let strength = 0;
        let text = 'Faible';
        let color = 'bg-red-500';
        let width = '0%';

        if (password.length >= 8) strength += 25;
        if (/[A-Z]/.test(password)) strength += 25;
        if (/[a-z]/.test(password)) strength += 25;
        if (/[0-9]/.test(password)) strength += 25;

        if (strength >= 75) {
            text = 'Fort';
            color = 'bg-green-500';
            width = '100%';
        } else if (strength >= 50) {
            text = 'Moyen';
            color = 'bg-yellow-500';
            width = '66%';
        } else if (strength >= 25) {
            text = 'Faible';
            color = 'bg-orange-500';
            width = '33%';
        }

        strengthBar.className = `h-2 rounded-full ${color} transition-all duration-500`;
        strengthBar.style.width = width;
        strengthText.textContent = text;
    }

    // Toggle visibilité mot de passe
    window.togglePassword = function(fieldId) {
        const field = document.getElementById(fieldId);
        const icon = field.parentNode.querySelector('i');
        
        if (field.type === 'password') {
            field.type = 'text';
            icon.className = 'fas fa-eye-slash';
        } else {
            field.type = 'password';
            icon.className = 'fas fa-eye';
        }
    }

    // Validation à la soumission
    form.addEventListener('submit', function(e) {
        let isValid = true;
        
        // Validation des champs requis
        const requiredFields = form.querySelectorAll('[required]');
        requiredFields.forEach(field => {
            if (!field.value.trim()) {
                isValid = false;
                showError(field.name, 'Ce champ est requis');
                
                // Animation de shake
                field.style.animation = 'shake 0.5s';
                setTimeout(() => {
                    field.style.animation = '';
                }, 500);
            }
        });

        // Validation confirmation mot de passe
        if (password.value !== confirmPassword.value) {
            isValid = false;
            showError('confirm_password', 'Les mots de passe ne correspondent pas');
        }

        // Validation conditions
        const conditions = document.getElementById('conditions');
        if (!conditions.checked) {
            isValid = false;
            showError('conditions', 'Vous devez accepter les termes et conditions');
        }

        if (!isValid) {
            e.preventDefault();
            
            // Animation globale du formulaire
            form.style.animation = 'shake 0.5s';
            setTimeout(() => {
                form.style.animation = '';
            }, 500);
        }
    });
});

// Animation de shake
const style = document.createElement('style');
style.textContent = `
    @keyframes shake {
        0%, 100% { transform: translateX(0); }
        25% { transform: translateX(-10px); }
        75% { transform: translateX(10px); }
    }
`;
document.head.appendChild(style);
</script>

<style>
/* Styles supplémentaires pour les inputs */
input:-webkit-autofill,
input:-webkit-autofill:hover,
input:-webkit-autofill:focus {
    -webkit-text-fill-color: white;
    -webkit-box-shadow: 0 0 0px 1000px rgba(255, 255, 255, 0.1) inset;
    transition: background-color 5000s ease-in-out 0s;
}

/* Focus states améliorés */
input:focus, select:focus {
    transform: translateY(-2px);
    transition: all 0.3s ease;
}

/* Animation des labels */
label {
    transition: all 0.3s ease;
}

/* Effet de pulsation pour les champs invalides */
input:invalid:not(:focus):not(:placeholder-shown) {
    animation: pulse 2s infinite;
}

@keyframes pulse {
    0%, 100% { border-color: rgba(239, 68, 68, 0.5); }
    50% { border-color: rgba(239, 68, 68, 1); }
}
</style>
{% endblock %}